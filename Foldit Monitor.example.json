{
    "launch": {
        "last_seen_foldit_parent": ""
    },
    "display": {
        "tooltip_lines": 15,
        "always_on_top": false,
        "show_puzzle_column": false,
        "window_position": {
            "x": 1,
            "y": 1
        },
        "stats_window_position": {
            "x": -1,
            "y": -1
        },
        "fonts": {
            "family": "DejaVu Sans Mono",
            "normal_size": 9,
            "tooltip_size": 7,
            "stats_size": 7
        },
        "active_palette": "balanced",
        "stale_tick_limit": 100,
        "script_type_fallback_max_length": 10,
        "stats_ui_backend": "tk",
        "stats_last_puzzle": ""
    },
    "network": {
        "default_port": 8000,
        "default_address": "127.0.0.1",
        "server_timeout": 10,
        "password": "fold.it",
        "auto_reconnect": true,
        "max_artifact_bytes": 536870912,
        "artifact_chunk_bytes": 262144,
        "startup_connections": [],
        "startup_connections_description": "\"startup_connections\" holds the list of addresses and ports to automatically connect to at startup."
    },
    "sound": {
        "alert_file": "alert.wav",
        "volume": 1
    },
    "logging": {
        "max_lines": 400,
        "script_exclusions": [
            "c-w",
            "other_script_name"
        ],
        "exclude_score_strings": [
            "Group rank",
            "ignore other score string"
        ],
        "logs_folder": "puzzle_logs",
        "stats_save_interval_minutes": 30,
        "stats_score_decimals": 0,
        "save_logs_immediately": true,
        "managed_log_exports": true,
        "log_format": {
            "column_separator": "||",
            "value_separator": " | "
        },
        "max_line_length": 100
    },
    "backup": {
        "folder_name": "foldit_backup",
        "save_to_backup": true
    },
    "script_type_mapping": {
        "ideali": {
            "name": "Microidealize",
            "column_number": 1
        },
        "jet": {
            "name": "JET",
            "column_number": 1
        },
